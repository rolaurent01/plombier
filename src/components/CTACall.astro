---
import siteData from '../data/site-data.json';

export interface Props {
  variant?: 'floating' | 'inline';
  text?: string;
}

const { variant = 'inline', text } = Astro.props;
const phone = siteData.company.phone;
const phoneRaw = siteData.company.phoneRaw;
const displayText = text || `Appeler — ${phone}`;
const isFloating = variant === 'floating';
---

<a
  href={`tel:${phoneRaw}`}
  class:list={['cta-call', { 'cta-floating': isFloating, 'cta-inline': !isFloating }]}
  aria-label={`Appeler le ${phone}`}
>
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
  <span>{displayText}</span>
</a>

<style>
  .cta-call {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-weight: 700;
    font-size: var(--text-base);
    color: #fff;
    background-color: var(--color-accent);
    border-radius: var(--radius-full);
    transition: background-color var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
    text-decoration: none;
    min-height: 48px;
  }

  .cta-call:hover {
    background-color: var(--color-accent-dark);
    transform: scale(1.03);
  }

  /* --- Floating (mobile only) --- */
  .cta-floating {
    position: fixed;
    bottom: calc(16px + env(safe-area-inset-bottom, 0px));
    left: 50%;
    transform: translateX(-50%);
    z-index: 900;
    padding: 0.875rem 1.75rem;
    box-shadow: 0 4px 20px rgba(244, 162, 97, 0.5), 0 2px 8px rgba(0, 0, 0, 0.15);
    font-size: var(--text-lg);
    animation: cta-pulse 3s ease-in-out infinite;
  }

  .cta-floating:hover {
    transform: translateX(-50%) scale(1.05);
  }

  @media (min-width: 1024px) {
    .cta-floating {
      display: none;
    }
  }

  @keyframes cta-pulse {
    0%, 100% { box-shadow: 0 4px 20px rgba(244, 162, 97, 0.5), 0 2px 8px rgba(0, 0, 0, 0.15); }
    50% { box-shadow: 0 4px 30px rgba(244, 162, 97, 0.7), 0 2px 12px rgba(0, 0, 0, 0.2); }
  }

  /* --- Inline --- */
  .cta-inline {
    padding: 0.875rem 1.75rem;
    box-shadow: var(--shadow-cta);
  }
</style>
