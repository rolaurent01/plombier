---
import siteData from '../data/site-data.json';
import { Phone } from '@lucide/astro';

export interface Props {
  variant?: 'floating' | 'inline';
  text?: string;
}

const { variant = 'inline', text } = Astro.props;
const phone = siteData.company.phone;
const phoneRaw = siteData.company.phoneRaw;
const displayText = text || `Appeler — ${phone}`;
const isFloating = variant === 'floating';
---

<a
  href={`tel:${phoneRaw}`}
  class:list={['cta-call', { 'cta-floating': isFloating, 'cta-inline': !isFloating }]}
  aria-label={`Appeler le ${phone}`}
>
  <Phone size={20} strokeWidth={2.5} aria-hidden="true" />
  <span>{displayText}</span>
</a>

<style>
  .cta-call {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-weight: 700;
    font-size: var(--text-base);
    color: #fff;
    background-color: var(--color-accent);
    border-radius: var(--radius-full);
    transition: background-color var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
    text-decoration: none;
    min-height: 48px;
  }

  .cta-call:hover {
    background-color: var(--color-accent-dark);
    transform: scale(1.03);
  }

  /* --- Floating (mobile only) --- */
  .cta-floating {
    position: fixed;
    bottom: calc(16px + env(safe-area-inset-bottom, 0px));
    left: 50%;
    transform: translateX(-50%);
    z-index: 900;
    padding: 0.875rem 1.75rem;
    box-shadow: 0 4px 20px rgba(244, 162, 97, 0.5), 0 2px 8px rgba(0, 0, 0, 0.15);
    font-size: var(--text-lg);
    animation: cta-pulse 3s ease-in-out infinite;
  }

  .cta-floating:hover {
    transform: translateX(-50%) scale(1.05);
  }

  @media (min-width: 1024px) {
    .cta-floating {
      display: none;
    }
  }

  @keyframes cta-pulse {
    0%, 100% { box-shadow: 0 4px 20px rgba(244, 162, 97, 0.5), 0 2px 8px rgba(0, 0, 0, 0.15); }
    50% { box-shadow: 0 4px 30px rgba(244, 162, 97, 0.7), 0 2px 12px rgba(0, 0, 0, 0.2); }
  }

  /* --- Inline --- */
  .cta-inline {
    padding: 0.875rem 1.75rem;
    box-shadow: var(--shadow-cta);
  }
</style>
