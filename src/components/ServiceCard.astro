---
import { Droplet, Wrench, Flame, Bath, Search, Heater, Hammer, ArrowRight } from '@lucide/astro';

export interface Props {
  slug: string;
  title: string;
  shortDescription: string;
  icon: string;
  priceFrom: number;
}

const { slug, title, shortDescription, priceFrom } = Astro.props;

const iconMap: Record<string, string> = {
  'fuite-eau-lyon': 'droplet',
  'debouchage-canalisation-lyon': 'wrench',
  'reparation-chauffe-eau-lyon': 'flame',
  'wc-bouche-lyon': 'bath',
  'recherche-fuite-lyon': 'search',
  'installation-chauffe-eau-lyon': 'heater',
  'renovation-salle-de-bain-lyon': 'hammer',
};

const iconName = iconMap[slug] || 'wrench';
---

<a href={`/services/${slug}/`} class="service-card card">
  <div class="service-icon-wrap" aria-hidden="true">
    {iconName === 'droplet' && <Droplet size={28} strokeWidth={1.5} />}
    {iconName === 'wrench' && <Wrench size={28} strokeWidth={1.5} />}
    {iconName === 'flame' && <Flame size={28} strokeWidth={1.5} />}
    {iconName === 'bath' && <Bath size={28} strokeWidth={1.5} />}
    {iconName === 'search' && <Search size={28} strokeWidth={1.5} />}
    {iconName === 'heater' && <Heater size={28} strokeWidth={1.5} />}
    {iconName === 'hammer' && <Hammer size={28} strokeWidth={1.5} />}
  </div>
  <h3 class="service-title">{title}</h3>
  <p class="service-desc">{shortDescription}</p>
  <span class="service-price">À partir de {priceFrom}€</span>
  <span class="service-link">
    En savoir plus
    <ArrowRight size={16} aria-hidden="true" />
  </span>
</a>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-text);
  }

  .service-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, rgba(27, 73, 101, 0.08), rgba(27, 73, 101, 0.03));
    color: var(--color-primary);
    margin-bottom: var(--space-md);
    border: 1px solid rgba(27, 73, 101, 0.08);
    transition: all var(--transition-base);
  }

  .service-card:hover .service-icon-wrap {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    color: #fff;
    border-color: transparent;
  }

  .service-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--color-primary-dark);
    margin-bottom: var(--space-sm);
  }

  .service-desc {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    flex-grow: 1;
    line-height: 1.6;
  }

  .service-price {
    display: inline-block;
    font-weight: 600;
    color: var(--color-accent-dark);
    font-size: var(--text-sm);
    margin-bottom: var(--space-sm);
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-primary);
    font-weight: 600;
    font-size: var(--text-sm);
    transition: gap var(--transition-fast);
  }

  .service-card:hover .service-link {
    gap: var(--space-sm);
    color: var(--color-accent);
  }
</style>
