---
export interface Props {
  slug: string;
  title: string;
  shortDescription: string;
  icon: string;
  priceFrom: number;
}

const { slug, title, shortDescription, priceFrom } = Astro.props;

const svgIcons: Record<string, string> = {
  'fuite-eau-lyon': '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>',
  'debouchage-canalisation-lyon': '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
  'reparation-chauffe-eau-lyon': '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>',
  'wc-bouche-lyon': '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16"/><path d="M4 10h16"/><path d="M6 10v3a6 6 0 0 0 5 5.91V22"/><path d="M18 10v3a6 6 0 0 1-5 5.91V22"/><path d="M10 2h4"/><path d="M12 2v8"/></svg>',
  'recherche-fuite-lyon': '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>',
  'installation-chauffe-eau-lyon': '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/><path d="M12 8v4"/><path d="M10 10h4"/><circle cx="12" cy="15" r="1"/></svg>',
  'renovation-salle-de-bain-lyon': '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h8"/><path d="M4 18V6a2 2 0 0 1 2-2h1"/><path d="M20 18V12h-8"/><path d="m7 22 5-10 5 10"/></svg>',
};

const svgIcon = svgIcons[slug] || '';
---

<a href={`/services/${slug}/`} class="service-card card">
  <div class="service-icon-wrap" aria-hidden="true">
    <Fragment set:html={svgIcon} />
  </div>
  <h3 class="service-title">{title}</h3>
  <p class="service-desc">{shortDescription}</p>
  <span class="service-price">À partir de {priceFrom}€</span>
  <span class="service-link">
    En savoir plus
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
  </span>
</a>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-text);
  }

  .service-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, rgba(27, 73, 101, 0.08), rgba(27, 73, 101, 0.03));
    color: var(--color-primary);
    margin-bottom: var(--space-md);
    border: 1px solid rgba(27, 73, 101, 0.08);
    transition: all var(--transition-base);
  }

  .service-card:hover .service-icon-wrap {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    color: #fff;
    border-color: transparent;
  }

  .service-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--color-primary-dark);
    margin-bottom: var(--space-sm);
  }

  .service-desc {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    flex-grow: 1;
    line-height: 1.6;
  }

  .service-price {
    display: inline-block;
    font-weight: 600;
    color: var(--color-accent-dark);
    font-size: var(--text-sm);
    margin-bottom: var(--space-sm);
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-primary);
    font-weight: 600;
    font-size: var(--text-sm);
    transition: gap var(--transition-fast);
  }

  .service-card:hover .service-link {
    gap: var(--space-sm);
    color: var(--color-accent);
  }
</style>
