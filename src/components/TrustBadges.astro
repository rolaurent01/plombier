---
import { Clock, Zap, FileText, ShieldCheck, Star } from '@lucide/astro';

const badges = [
  { icon: 'clock', text: '24h/24 — 7j/7' },
  { icon: 'zap', text: 'Intervention 30 min' },
  { icon: 'file-text', text: 'Devis gratuit' },
  { icon: 'shield-check', text: 'Travaux garantis' },
  { icon: 'star', text: '5/5 sur Google' },
];
---

<div class="trust-badges">
  {badges.map((badge) => (
    <div class="trust-badge">
      <span class="badge-icon" aria-hidden="true">
        {badge.icon === 'clock' && <Clock size={16} />}
        {badge.icon === 'zap' && <Zap size={16} />}
        {badge.icon === 'file-text' && <FileText size={16} />}
        {badge.icon === 'shield-check' && <ShieldCheck size={16} />}
        {badge.icon === 'star' && <Star size={16} fill="currentColor" strokeWidth={0} />}
      </span>
      <span class="badge-text">{badge.text}</span>
    </div>
  ))}
</div>

<style>
  .trust-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
  }

  .trust-badge {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-md);
    background-color: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(4px);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
    color: #fff;
    white-space: nowrap;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .badge-icon {
    display: inline-flex;
    align-items: center;
  }

  /* On light background variant */
  :global(.section:not(.section-dark)) .trust-badge,
  :global(.hero-badges-light) .trust-badge {
    background-color: #fff;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }
</style>
