---
import BaseLayout from './BaseLayout.astro';
import CTACall from '../components/CTACall.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import siteData from '../data/site-data.json';
import services from '../data/services.json';
import zones from '../data/zones.json';
import testimonials from '../data/testimonials.json';
import { generateFAQSchema } from '../utils/seo';

export interface Props {
  slug: string;
  seoTitle: string;
  metaDescription: string;
  h1: string;
  subtitle: string;
  problemTitle: string;
  problemText: string;
  causesTitle: string;
  causes: string[];
  interventionTitle: string;
  steps: string[];
  priceLabel: string;
  priceNote: string;
  faqs: { question: string; answer: string }[];
}

const {
  slug,
  seoTitle,
  metaDescription,
  h1,
  subtitle,
  problemTitle,
  problemText,
  causesTitle,
  causes,
  interventionTitle,
  steps,
  priceLabel,
  priceNote,
  faqs,
} = Astro.props;

const phone = siteData.company.phone;
const phoneRaw = siteData.company.phoneRaw;

const faqSchema = generateFAQSchema(faqs);

const testimonial = testimonials.find((t) => t.service === slug)
  || testimonials.find((t) => t.service.includes(slug.split('-')[0]))
  || testimonials[0];

const otherServices = services.filter((s) => s.slug !== slug);

// Mapping service → zones pertinentes (3 zones proches du type d'intervention)
const serviceZoneMap: Record<string, string[]> = {
  'fuite-eau-lyon': ['plombier-lyon-3', 'plombier-lyon-6', 'plombier-villeurbanne'],
  'debouchage-canalisation-lyon': ['plombier-lyon-1', 'plombier-lyon-7', 'plombier-bron'],
  'reparation-chauffe-eau-lyon': ['plombier-lyon-8', 'plombier-lyon-2', 'plombier-caluire'],
  'wc-bouche-lyon': ['plombier-lyon-4', 'plombier-lyon-9', 'plombier-venissieux'],
  'recherche-fuite-lyon': ['plombier-lyon-5', 'plombier-lyon-3', 'plombier-decines'],
  'installation-chauffe-eau-lyon': ['plombier-lyon-6', 'plombier-lyon-8', 'plombier-villeurbanne'],
  'renovation-salle-de-bain-lyon': ['plombier-lyon-2', 'plombier-lyon-6', 'plombier-caluire'],
};
const relatedZones = (serviceZoneMap[slug] || ['plombier-lyon-3', 'plombier-lyon-6', 'plombier-villeurbanne'])
  .map((s) => zones.find((z) => z.slug === s))
  .filter((z): z is typeof zones[number] => z !== undefined);

// Mapping service → articles blog pertinents
const serviceBlogMap: Record<string, { slug: string; title: string }[]> = {
  'fuite-eau-lyon': [
    { slug: 'que-faire-fuite-eau', title: "Que faire en cas de fuite d'eau ?" },
    { slug: 'comment-couper-eau-appartement', title: "Comment couper l'eau dans un appartement ?" },
  ],
  'debouchage-canalisation-lyon': [
    { slug: 'comment-deboucher-evier', title: "Comment déboucher un évier ?" },
    { slug: 'wc-bouche-que-faire', title: "WC bouché : que faire ?" },
  ],
  'reparation-chauffe-eau-lyon': [
    { slug: 'pourquoi-chauffe-eau-fuit', title: "Pourquoi mon chauffe-eau fuit ?" },
    { slug: 'que-faire-fuite-eau', title: "Que faire en cas de fuite d'eau ?" },
  ],
  'wc-bouche-lyon': [
    { slug: 'wc-bouche-que-faire', title: "WC bouché : que faire ?" },
    { slug: 'comment-deboucher-evier', title: "Comment déboucher un évier ?" },
  ],
  'recherche-fuite-lyon': [
    { slug: 'que-faire-fuite-eau', title: "Que faire en cas de fuite d'eau ?" },
    { slug: 'comment-couper-eau-appartement', title: "Comment couper l'eau dans un appartement ?" },
  ],
  'installation-chauffe-eau-lyon': [
    { slug: 'pourquoi-chauffe-eau-fuit', title: "Pourquoi mon chauffe-eau fuit ?" },
  ],
  'renovation-salle-de-bain-lyon': [
    { slug: 'que-faire-fuite-eau', title: "Que faire en cas de fuite d'eau ?" },
    { slug: 'pourquoi-chauffe-eau-fuit', title: "Pourquoi mon chauffe-eau fuit ?" },
  ],
};
const relatedArticles = serviceBlogMap[slug] || [];
---

<BaseLayout
  title={seoTitle}
  description={metaDescription}
  canonicalPath={`/services/${slug}/`}
  ogType="article"
  extraSchema={[faqSchema]}
>
  <!-- SECTION 1 — Hero compact -->
  <section class="service-hero">
    <div class="container">
      <div class="service-hero-content fade-in">
        <span class="hero-badge">Intervention en 30 min</span>
        <h1>{h1}</h1>
        <p class="hero-subtitle">{subtitle}</p>
        <div class="hero-actions">
          <CTACall variant="inline" text={`Appeler — ${phone}`} />
        </div>
        <div class="hero-trust">
          <span class="hero-trust-item">24h/24 — 7j/7</span>
          <span class="hero-trust-sep" aria-hidden="true">|</span>
          <span class="hero-trust-item">Devis gratuit</span>
          <span class="hero-trust-sep" aria-hidden="true">|</span>
          <span class="hero-trust-item">5/5 sur Google</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 2 — Le problème -->
  <section class="section" id="probleme">
    <div class="container">
      <div class="content-block fade-in">
        <h2>{problemTitle}</h2>
        <p class="problem-text">{problemText}</p>
      </div>
    </div>
  </section>

  <!-- SECTION 3 — Les causes courantes -->
  <section class="section section-alt" id="causes">
    <div class="container">
      <div class="section-title fade-in">
        <h2>{causesTitle}</h2>
      </div>
      <ul class="causes-list fade-in">
        {causes.map((cause) => (
          <li class="cause-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="cause-icon"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path><path d="m9 12 2 2 4-4"></path></svg>
            <span>{cause}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- SECTION 4 — Notre intervention -->
  <section class="section" id="intervention">
    <div class="container">
      <div class="section-title fade-in">
        <h2>{interventionTitle}</h2>
      </div>
      <ol class="steps-list fade-in">
        {steps.map((step, index) => (
          <li class="step-item">
            <span class="step-number">{index + 1}</span>
            <span class="step-text">{step}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- SECTION 5 — Tarif -->
  <section class="section section-alt" id="tarif">
    <div class="container text-center fade-in">
      <h2>Tarif indicatif</h2>
      <div class="price-highlight">
        <span class="price-value">{priceLabel}</span>
        <span class="price-detail">{priceNote}</span>
      </div>
      <p class="price-cta-text">Devis gratuit et sans engagement avant chaque intervention.</p>
      <CTACall variant="inline" text={`Appeler pour un devis — ${phone}`} />
    </div>
  </section>

  <!-- SECTION 6 — Témoignage client -->
  <section class="section" id="avis">
    <div class="container">
      <div class="section-title fade-in">
        <h2>Ce que disent nos clients</h2>
      </div>
      <div class="testimonial-wrapper fade-in">
        <TestimonialCard
          name={testimonial.name}
          zone={testimonial.zone}
          rating={testimonial.rating}
          text={testimonial.text}
        />
      </div>
    </div>
  </section>

  <!-- SECTION 7 — FAQ spécifique -->
  <section class="section section-alt" id="faq">
    <div class="container">
      <div class="section-title fade-in">
        <h2>Questions fréquentes</h2>
      </div>
      <div class="fade-in">
        <FAQAccordion faqs={faqs} />
      </div>
    </div>
  </section>

  <!-- SECTION 8 — Zones d'intervention -->
  {relatedZones.length > 0 && (
    <section class="section" id="zones-intervention">
      <div class="container">
        <div class="section-title fade-in">
          <h2>Nos zones d'intervention</h2>
          <p>Nous intervenons rapidement dans tout Lyon et sa métropole</p>
        </div>
        <div class="zone-links-grid fade-in">
          {relatedZones.map((zone) => (
            <a href={`/zones/${zone.slug}/`} class="zone-link-card card">
              <h3>{zone.name}</h3>
              <span class="zone-link-code">{zone.postalCode}</span>
              <span class="zone-link-time">Intervention en {zone.tempsIntervention}</span>
              <span class="zone-link-arrow">Voir la page &rarr;</span>
            </a>
          ))}
        </div>
        <p class="text-center fade-in" style="margin-top: var(--space-lg);">
          <a href="/#zones" class="back-home-link">Voir toutes nos zones d'intervention</a>
        </p>
      </div>
    </section>
  )}

  <!-- SECTION 9 — Articles associés -->
  {relatedArticles.length > 0 && (
    <section class="section section-alt" id="articles-associes">
      <div class="container">
        <div class="section-title fade-in">
          <h2>Articles et guides utiles</h2>
        </div>
        <div class="blog-links fade-in">
          {relatedArticles.map((article) => (
            <a href={`/blog/${article.slug}/`} class="blog-link-item">
              <span class="blog-link-title">{article.title}</span>
              <span class="blog-link-arrow">Lire l'article &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- SECTION 10 — Autres services -->
  <section class="section" id="autres-services">
    <div class="container">
      <div class="section-title fade-in">
        <h2>Vous avez peut-être aussi besoin de…</h2>
      </div>
      <div class="grid grid-3 fade-in">
        {otherServices.map((service) => (
          <ServiceCard {...service} />
        ))}
      </div>
      <div class="text-center fade-in" style="margin-top: var(--space-xl);">
        <a href="/" class="back-home-link">Retour à l'accueil</a>
      </div>
    </div>
  </section>

  <!-- SECTION 9 — CTA final -->
  <section class="section cta-final-section">
    <div class="container text-center">
      <h2 class="cta-final-title fade-in">Besoin d'un plombier ? Appelez maintenant</h2>
      <p class="cta-final-subtitle fade-in">Disponible 24h/24 — Intervention en 30 minutes — Devis gratuit</p>
      <div class="cta-final-phone fade-in">
        <a href={`tel:${phoneRaw}`} class="phone-display">{phone}</a>
      </div>
      <div class="cta-final-actions fade-in">
        <CTACall variant="inline" text={`Appeler — ${phone}`} />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* --- Hero compact --- */
  .service-hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    padding-block: var(--space-3xl) var(--space-2xl);
    text-align: center;
  }

  .service-hero-content {
    max-width: 700px;
    margin-inline: auto;
  }

  .hero-badge {
    display: inline-block;
    background-color: var(--color-accent);
    color: #fff;
    font-weight: 700;
    font-size: var(--text-sm);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-lg);
    letter-spacing: 0.02em;
  }

  .service-hero h1 {
    color: #fff;
    margin-bottom: var(--space-md);
  }

  .hero-subtitle {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--text-lg);
    margin-bottom: var(--space-xl);
    line-height: 1.6;
  }

  .hero-actions {
    margin-bottom: var(--space-lg);
  }

  .hero-trust {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
    font-weight: 500;
  }

  .hero-trust-sep {
    opacity: 0.4;
  }

  /* --- Problem section --- */
  .content-block {
    max-width: 750px;
    margin-inline: auto;
  }

  .content-block h2 {
    margin-bottom: var(--space-lg);
    text-align: center;
  }

  .problem-text {
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--color-text);
    text-align: center;
  }

  /* --- Causes list --- */
  .causes-list {
    max-width: 650px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .cause-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text);
  }

  .cause-icon {
    flex-shrink: 0;
    color: var(--color-success);
  }

  /* --- Steps list --- */
  .steps-list {
    max-width: 650px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    counter-reset: none;
  }

  .step-item {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-md) var(--space-lg);
    background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    border-left: 4px solid var(--color-primary);
  }

  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    background-color: var(--color-primary);
    color: #fff;
    font-weight: 700;
    font-size: var(--text-sm);
    border-radius: 50%;
  }

  .step-text {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text);
  }

  /* --- Price highlight --- */
  .price-highlight {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    margin-block: var(--space-xl);
    padding: var(--space-xl);
    background: #fff;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    max-width: 450px;
    margin-inline: auto;
  }

  .price-value {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--color-accent-dark);
  }

  @media (min-width: 768px) {
    .price-value {
      font-size: var(--text-4xl);
    }
  }

  .price-detail {
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }

  .price-cta-text {
    font-size: var(--text-base);
    color: var(--color-text-light);
    margin-bottom: var(--space-lg);
  }

  /* --- Testimonial --- */
  .testimonial-wrapper {
    max-width: 550px;
    margin-inline: auto;
  }

  /* --- Back home link --- */
  .back-home-link {
    display: inline-block;
    font-weight: 600;
    color: var(--color-primary);
    font-size: var(--text-base);
    transition: color var(--transition-fast);
  }

  .back-home-link:hover {
    color: var(--color-accent);
  }

  /* --- Zone links --- */
  .zone-links-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .zone-links-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .zone-link-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-decoration: none;
    text-align: center;
    padding: var(--space-xl) var(--space-lg);
  }

  .zone-link-card h3 {
    font-size: var(--text-xl);
    color: var(--color-primary);
    margin-bottom: var(--space-xs);
  }

  .zone-link-code {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    font-weight: 500;
  }

  .zone-link-time {
    font-size: var(--text-sm);
    color: var(--color-accent-dark);
    font-weight: 600;
  }

  .zone-link-arrow {
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 600;
    margin-top: var(--space-sm);
    transition: color var(--transition-fast);
  }

  .zone-link-card:hover .zone-link-arrow {
    color: var(--color-accent);
  }

  /* --- Blog links --- */
  .blog-links {
    max-width: 700px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .blog-link-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    transition: box-shadow var(--transition-fast), transform var(--transition-fast);
    min-height: 48px;
  }

  .blog-link-item:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .blog-link-title {
    font-weight: 600;
    color: var(--color-primary-dark);
    font-size: var(--text-base);
  }

  .blog-link-arrow {
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 600;
    white-space: nowrap;
    transition: color var(--transition-fast);
  }

  .blog-link-item:hover .blog-link-arrow {
    color: var(--color-accent);
  }

  /* --- CTA Final (reused from index) --- */
  .cta-final-section {
    background-color: var(--color-primary);
  }

  .cta-final-title {
    font-size: var(--text-3xl);
    color: #fff;
    margin-bottom: var(--space-sm);
  }

  @media (min-width: 768px) {
    .cta-final-title {
      font-size: var(--text-4xl);
    }
  }

  .cta-final-subtitle {
    color: rgba(255, 255, 255, 0.8);
    font-size: var(--text-lg);
    margin-bottom: var(--space-xl);
  }

  .cta-final-phone {
    margin-bottom: var(--space-lg);
  }

  .phone-display {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 800;
    color: #fff;
    text-decoration: none;
    transition: color var(--transition-fast);
    letter-spacing: 0.02em;
  }

  @media (min-width: 768px) {
    .phone-display {
      font-size: var(--text-5xl);
    }
  }

  .phone-display:hover {
    color: var(--color-accent-light);
  }

  .cta-final-actions {
    display: flex;
    justify-content: center;
  }
</style>
